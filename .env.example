# ─── Portas (ajuste para não conflitar com outros projetos) ───────────────────
APP_PORT=7900          # Next.js — aapanel faz proxy reverso para esta porta
# POSTGRES_PORT=7901   # Descomente APENAS para acesso externo ao banco (dev/debug)

# ─── Banco de Dados ───────────────────────────────────────────────────────────
DATABASE_URL="postgresql://kmundo:senha@postgres:5432/kmundo"
POSTGRES_DB=kmundo
POSTGRES_USER=kmundo
POSTGRES_PASSWORD=senha

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=gere-com-openssl-rand-base64-32
NEXTAUTH_URL=http://kmundowarehouse.com
AUTH_SECRET=mesmo-valor-do-nextauth-secret

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ─── Admin inicial (usado no seed) ───────────────────────────────────────────
ADMIN_EMAIL=admin@kmundowarehouse.com
ADMIN_PASSWORD=senha-inicial-forte

# ─── Upload ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads

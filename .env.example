# ─── Portas (ajuste para não conflitar com outros projetos) ───────────────────
# O aaPanel/Nginx do servidor faz proxy reverso para APP_PORT.
# Nunca use 80, 443, 3000 ou 5432 — geralmente já estão em uso.
APP_PORT=8300          # porta externa do Next.js (range 8300-8320)
POSTGRES_PORT=8301     # porta externa do Postgres (acesso local/debug)

# ─── Banco de Dados ───────────────────────────────────────────────────────────
DATABASE_URL="postgresql://kmundo:senha@postgres:5432/kmundo"
POSTGRES_DB=kmundo
POSTGRES_USER=kmundo
POSTGRES_PASSWORD=senha

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=gere-com-openssl-rand-base64-32
NEXTAUTH_URL=http://kmundowarehouse.com
AUTH_SECRET=mesmo-valor-do-nextauth-secret

# ─── Email (Resend — notificações automáticas) ────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ─── Email (IMAP/SMTP — caixa de entrada admin) ───────────────────────────────
MAIL_HOST=mail.kmundowarehouse.com
MAIL_USER=contato@kmundowarehouse.com
MAIL_PASSWORD=sua-senha-email
MAIL_IMAP_PORT=993
MAIL_SMTP_PORT=587

# ─── Admin inicial (usado no seed) ───────────────────────────────────────────
ADMIN_EMAIL=admin@kmundowarehouse.com
ADMIN_PASSWORD=senha-inicial-forte

# ─── Upload ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads

FROM node:20-alpine
WORKDIR /app

# openssl necessário para o Prisma engine no Alpine
RUN apk add --no-cache openssl openssl-dev libc6-compat

# Instala dependências separado do código — Docker cacheia esta camada
# e só reinstala se package.json mudar
COPY package*.json ./
RUN npm ci --legacy-peer-deps

# Copia o código e gera o client do Prisma
COPY . .
RUN npx prisma generate

EXPOSE 3000

# Entrypoint roda migrate + seed automaticamente antes de iniciar
COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]
